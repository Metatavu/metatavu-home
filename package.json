    "react-dom": "^18.3.1",
    "react-hook-form": "^7.46.1",
    "react-markdown": "^8.0.6",
    "react-router": "^6.15.0",
    "react-router-dom": "^6.15.0",
    "react-select": "^5.7.4",
    "recharts": "^2.13.0",
    "swiper": "^11.2.6"
  },
