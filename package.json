    "@biomejs/biome": "^2.2.5",
    "@openapitools/openapi-generator-cli": "2.5.2",
    "@types/lodash": "^4.17.14",
    "@types/luxon": "^3.3.7",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
